# ==========================================
# REWEARA BACKEND ENVIRONMENT VARIABLES CONFIG
# ==========================================

# 🚀 APP CONFIGURATION
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# 🛢️ DATABASE CONFIGURATION
# Standard MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/reweara?retryWrites=true&w=majority

# 🔐 AUTHENTICATION SECRETS
JWT_SECRET=your_jwt_access_secret_hash_key_here_32_characters
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your_jwt_refresh_secret_hash_key_here_64_characters
REFRESH_EXPIRES_IN=7d

# 💳 RAZORPAY GATEWAY PAYMENTS
RAZORPAY_KEY_ID=rzp_test_yourKeyIdHere
RAZORPAY_SECRET=yourRazorpaySecretHere

# 🖼️ CLOUDINARY MEDIA CDN
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# 👤 SUPER ADMIN INITIAL SEEDING
SUPER_ADMIN_NAME=your_super_admin_name
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=your_secure_super_admin_password_hash_strength
SUPER_ADMIN_PHONE=10_digit_indian_number_here

# ✉️ ABSTRACTAPI EMAIL REPUTATION KEY
ABSTRACT_EMAIL_API_KEY=your_abstractapi_email_reputation_key_here
